# ─── Supabase (required) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Image generation (required for visualizations) ──────────────────
# Google Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_GEMINI_API_KEY=
# Image model. Default favors quality; switch to gemini-2.5-flash-image for
# faster, lower-cost generation.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ─── Email (required to deliver results to leads) ────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Vizzion <noreply@vizzion.io>

# ─── Widget security ─────────────────────────────────────────────────
WIDGET_IP_HASH_SALT=
# Cloudflare Turnstile (only needed for rate-capped widgets)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Cron backstop (recommended in production) ───────────────────────
# Shared secret so only Vercel Cron can trigger the job sweeper.
CRON_SECRET=

# ─── Site / misc ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WIDGET_SCRIPT_SRC=
# Slack webhook for marketing form submissions (server-side only)
SLACK_WEBHOOK_URL=
