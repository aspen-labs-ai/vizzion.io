{
  "crons": [
    {
      "path": "/api/cron/process-generation-jobs",
      "schedule": "*/5 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.vizzion.io"
        }
      ],
      "destination": "https://vizzion.io/:path*",
      "permanent": true
    }
  ]
}
